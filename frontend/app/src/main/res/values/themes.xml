<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WhatCanICook" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores principales del tema -->
        <item name="colorPrimary">@color/pumpkin_orange</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/pumpkin_orange_light</item>
        <item name="colorOnPrimaryContainer">@color/black</item>

        <!-- Colores de fondo y superficie -->
        <item name="android:windowBackground">@color/background_app</item>
        <item name="colorSurface">@color/surface_white</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Personalización de componentes -->
        <item name="materialButtonStyle">@style/Widget.App.Button.White</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
    </style>

    <style name="Theme.WhatCanICook" parent="Base.Theme.WhatCanICook" />

    <!-- Estilo para botones blancos con borde negro -->
    <style name="Widget.App.Button.White" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="strokeColor">@color/black</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.SmallComponent</item>
    </style>

    <!-- Estilo para Cajas de Texto (Inputs) con borde negro -->
    <style name="Widget.App.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/black</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="boxStrokeWidthFocused">2.5dp</item>
        <item name="hintTextColor">@color/pumpkin_orange</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <style name="ShapeAppearance.App.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>
</resources>