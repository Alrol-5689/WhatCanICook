<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.app.ui.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/activity_login">
        <action
            android:id="@+id/action_login_to_feed"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.app.ui.register.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/activity_register" />

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.app.ui.feed.FeedFragment"
        android:label="Feed"
        tools:layout="@layout/item_recipe" />

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.app.ui.favorites.FavoritesFragment"
        android:label="Favoritos"
        tools:layout="@layout/fragment_favorites" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.app.ui.profile.ProfileFragment"
        android:label="Perfil"
        tools:layout="@layout/activity_profile" />

    <fragment
        android:id="@+id/myRecipesFragment"
        android:name="com.app.ui.myrecipes.MyRecipesFragment"
        android:label="Mis recetas"
        tools:layout="@layout/fragment_my_recipes" />

    <fragment
        android:id="@+id/friendsFragment"
        android:name="com.app.ui.friends.FriendsFragment"
        android:label="Amigos"
        tools:layout="@layout/fragment_friends" />

    <fragment
        android:id="@+id/recipeCreateFragment"
        android:name="com.app.ui.recipes.create.RecipeCreateFragment"
        android:label="Crear receta"
        tools:layout="@layout/fragment_recipe_create" />

    <fragment
        android:id="@+id/userSearchFragment"
        android:name="com.app.ui.users.search.UserSearchFragment"
        android:label="Buscar usuarios"
        tools:layout="@layout/fragment_user_search" />

    <fragment
        android:id="@+id/pantryFragment"
        android:name="com.app.ui.recipes.PantryFragment"
        android:label="Mi Despensa"
        tools:layout="@layout/fragment_pantry">
        <action
            android:id="@+id/action_pantry_to_results"
            app:destination="@id/pantryResultsFragment" />
    </fragment>

    <fragment
        android:id="@+id/pantryResultsFragment"
        android:name="com.app.ui.recipes.PantryResultsFragment"
        android:label="Resultados"
        tools:layout="@layout/fragment_pantry_results">
        <action
            android:id="@+id/action_pantry_results_to_detail"
            app:destination="@id/recipeDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/recipeDetailFragment"
        android:name="com.app.ui.recipes.RecipeDetailFragment"
        android:label="Detalle"
        tools:layout="@layout/fragment_recipe_detail" />

</navigation>
